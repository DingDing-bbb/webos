{
  "id": "com.os.filemanager",
  "version": "1.0.0",
  "name": "File Manager",
  "nameLocalized": {
    "en": "File Manager",
    "zh-CN": "文件管理器",
    "zh-TW": "檔案管理員"
  },
  "description": "Browse and manage files on your system",
  "descriptionLocalized": {
    "en": "Browse and manage files on your system",
    "zh-CN": "浏览和管理系统文件",
    "zh-TW": "瀏覽和管理系統檔案"
  },
  "icon": "folder",
