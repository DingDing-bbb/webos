{
  "name": "@webos/sdk",
  "version": "0.0.1-alpha",
  "description": "WebOS Software Development Kit - Complete toolkit for building WebOS applications",
  "private": true,
  "type": "module",
  "main": "./packages/core/src/index.ts",
  "types": "./packages/core/src/index.ts",
  "bin": {
    "webos": "./packages/cli/bin/webos.ts",
    "webos-sdk": "./packages/cli/bin/webos.ts"
  },
  "exports": {
    ".": {
      "types": "./packages/core/src/index.ts",
      "default": "./packages/core/src/index.ts"
    },
    "./core": {
      "types": "./packages/core/src/index.ts",
      "default": "./packages/core/src/index.ts"
    },
    "./types": {
      "types": "./packages/types/src/index.ts",
      "default": "./packages/types/src/index.ts"
    },
    "./react": {
      "types": "./packages/react/src/index.ts",
      "default": "./packages/react/src/index.ts"
    },
    "./app-builder": {
      "types": "./packages/app-builder/src/index.ts",
      "default": "./packages/app-builder/src/index.ts"
    },
    "./cli": {
      "types": "./packages/cli/src/index.ts",
      "default": "./packages/cli/src/index.ts"
    },
    "./devtools": {
      "types": "./packages/devtools/src/index.ts",
      "default": "./packages/devtools/src/index.ts"
    },
    "./testing": {
      "types": "./packages/testing/src/index.ts",
      "default": "./packages/testing/src/index.ts"
    },
    "./templates": {
      "types": "./packages/templates/src/index.ts",
      "default": "./packages/templates/src/index.ts"
    }
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run build:all",
    "build:all": "echo 'Building all SDK packages...'",
    "dev": "bun run dev:all",
    "dev:all": "echo 'Starting development mode for all packages...'",
    "lint": "eslint packages/*/src --ext .ts,.tsx",
    "test": "bun test",
    "clean": "rm -rf packages/*/dist"
  },
  "dependencies": {
    "@webos/sdk-core": "workspace:*",
    "@webos/sdk-types": "workspace:*",
    "@webos/sdk-react": "workspace:*",
    "@webos/sdk-app-builder": "workspace:*",
    "@webos/sdk-cli": "workspace:*",
    "@webos/sdk-devtools": "workspace:*",
    "@webos/sdk-testing": "workspace:*",
    "@webos/sdk-templates": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "keywords": [
    "webos",
    "sdk",
    "operating-system",
    "web",
    "desktop",
    "application",
    "development"
  ],
  "author": "WebOS Team",
  "license": "MIT"
}
