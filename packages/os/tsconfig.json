{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@kernel": ["packages/kernel/src/index.ts"],
      "@kernel/*": ["packages/kernel/src/*"],
      "@kernel/types": ["packages/kernel/src/types.ts"],
      "@kernel/core/*": ["packages/kernel/src/core/*"],
      "@i18n": ["packages/i18n/src/index.ts"],
      "@i18n/*": ["packages/i18n/src/*"],
      "@ui": ["packages/ui/src/index.ts"],
      "@ui/*": ["packages/ui/src/*"],
      "@ui/base": ["packages/ui/src/base/index.ts"],
      "@ui/base/*": ["packages/ui/src/base/*"],
      "@ui/theme": ["packages/ui/src/theme/index.ts"],
      "@ui/theme/*": ["packages/ui/src/theme/*"],
      "@ui/display": ["packages/ui/src/display/index.ts"],
      "@ui/display/*": ["packages/ui/src/display/*"],
      "@ui/feedback": ["packages/ui/src/feedback/index.ts"],
      "@ui/feedback/*": ["packages/ui/src/feedback/*"],
      "@ui/input": ["packages/ui/src/input/index.ts"],
      "@ui/input/*": ["packages/ui/src/input/*"],
      "@ui/layout": ["packages/ui/src/layout/index.ts"],
      "@ui/layout/*": ["packages/ui/src/layout/*"],
      "@ui/navigation": ["packages/ui/src/navigation/index.ts"],
      "@ui/navigation/*": ["packages/ui/src/navigation/*"],
      "@ui/components/*": ["packages/ui/src/components/*"],
      "@ui/hooks": ["packages/ui/src/hooks/index.ts"],
      "@ui/utils": ["packages/ui/src/utils/index.ts"],
      "@webos/ui/*": ["packages/ui/src/*"],
      "@oobe": ["packages/oobe/src/index.tsx"],
      "@oobe/*": ["packages/oobe/src/*"],
      "@bootloader": ["packages/bootloader/src/index.ts"],
      "@bootloader/*": ["packages/bootloader/src/*"],
      "@recovery": ["packages/recovery/src/index.tsx"],
      "@recovery/*": ["packages/recovery/src/*"],
      "@tablet": ["packages/tablet/src/index.ts"],
      "@tablet/*": ["packages/tablet/src/*"],
      "@app": ["packages/apps/index.ts"],
      "@app/*": ["packages/apps/*"],
      "@apps": ["packages/apps/index.ts"],
      "@apps/*": ["packages/apps/*"],
      "@webos/sdk": ["packages/sdk/src/index.ts"],
      "@webos/sdk/*": ["packages/sdk/src/*"]
    }
  },
  "include": ["packages/**/*", "global.d.ts"],
  "exclude": ["node_modules", "dist"]
}
