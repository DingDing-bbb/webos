{
  admin off
}

:80 {
  encode gzip

  @static {
    path *.js *.css *.png *.jpg *.jpeg *.gif *.svg *.ico *.woff *.woff2 *.ttf *.eot *.wasm
  }
  header @static {
    Cache-Control "public, max-age=31536000, immutable"
  }

  handle_path /api/* {
    reverse_proxy localhost:3000
  }

  handle_path /_next/* {
    reverse_proxy localhost:3000
  }

  handle {
    reverse_proxy localhost:3000
  }

  log {
    output stdout
    format json
  }
}
