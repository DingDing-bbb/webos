{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@kernel": ["packages/os/packages/kernel/src/index.ts"],
      "@kernel/*": ["packages/os/packages/kernel/src/*"],
      "@kernel/types": ["packages/os/packages/kernel/src/types.ts"],
      "@kernel/core/*": ["packages/os/packages/kernel/src/core/*"],
      "@i18n": ["packages/os/packages/i18n/src/index.ts"],
      "@i18n/*": ["packages/os/packages/i18n/src/*"],
      "@ui": ["packages/os/packages/ui/src/index.ts"],
      "@ui/*": ["packages/os/packages/ui/src/*"],
      "@ui/base": ["packages/os/packages/ui/src/base/index.ts"],
      "@ui/base/*": ["packages/os/packages/ui/src/base/*"],
      "@ui/theme": ["packages/os/packages/ui/src/theme/index.ts"],
      "@ui/theme/*": ["packages/os/packages/ui/src/theme/*"],
      "@ui/display": ["packages/os/packages/ui/src/display/index.ts"],
      "@ui/display/*": ["packages/os/packages/ui/src/display/*"],
      "@ui/feedback": ["packages/os/packages/ui/src/feedback/index.ts"],
      "@ui/feedback/*": ["packages/os/packages/ui/src/feedback/*"],
      "@ui/input": ["packages/os/packages/ui/src/input/index.ts"],
      "@ui/input/*": ["packages/os/packages/ui/src/input/*"],
      "@ui/layout": ["packages/os/packages/ui/src/layout/index.ts"],
      "@ui/layout/*": ["packages/os/packages/ui/src/layout/*"],
      "@ui/navigation": ["packages/os/packages/ui/src/navigation/index.ts"],
      "@ui/navigation/*": ["packages/os/packages/ui/src/navigation/*"],
      "@ui/components/*": ["packages/os/packages/ui/src/components/*"],
      "@ui/hooks": ["packages/os/packages/ui/src/hooks/index.ts"],
      "@ui/utils": ["packages/os/packages/ui/src/utils/index.ts"],
      "@webos/ui": ["packages/os/packages/ui/src/index.ts"],
      "@webos/ui/*": ["packages/os/packages/ui/src/*"],
      "@oobe": ["packages/os/packages/oobe/src/index.tsx"],
      "@oobe/*": ["packages/os/packages/oobe/src/*"],
      "@bootloader": ["packages/os/packages/bootloader/src/index.ts"],
      "@bootloader/*": ["packages/os/packages/bootloader/src/*"],
      "@recovery": ["packages/os/packages/recovery/src/index.tsx"],
      "@recovery/*": ["packages/os/packages/recovery/src/*"],
      "@tablet": ["packages/os/packages/tablet/src/index.ts"],
      "@tablet/*": ["packages/os/packages/tablet/src/*"],
      "@app": ["packages/os/packages/apps/index.ts"],
      "@app/*": ["packages/os/packages/apps/*"],
      "@apps": ["packages/os/packages/apps/index.ts"],
      "@apps/*": ["packages/os/packages/apps/*"],
      "@webos/sdk": ["packages/os/packages/sdk/src/index.ts"],
      "@webos/sdk/*": ["packages/os/packages/sdk/src/*"]
    }
  },
  "include": ["packages/**/*", "site/**/*"],
  "exclude": ["node_modules", "dist", ".next"]
}
