{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@webos/kernel": ["packages/kernel/src/index.ts"],
      "@webos/kernel/*": ["packages/kernel/src/*"],
      "@webos/kernel/types": ["packages/kernel/src/types.ts"],
      "@webos/kernel/core/*": ["packages/kernel/src/core/*"],
      "@webos/ui": ["packages/ui/src/index.ts"],
      "@webos/ui/*": ["packages/ui/src/*"],
      "@webos/ui/base": ["packages/ui/src/base/index.ts"],
      "@webos/ui/base/*": ["packages/ui/src/base/*"],
      "@webos/ui/theme": ["packages/ui/src/theme/index.ts"],
      "@webos/ui/theme/*": ["packages/ui/src/theme/*"],
      "@webos/ui/display": ["packages/ui/src/display/index.ts"],
      "@webos/ui/display/*": ["packages/ui/src/display/*"],
      "@webos/ui/feedback": ["packages/ui/src/feedback/index.ts"],
      "@webos/ui/feedback/*": ["packages/ui/src/feedback/*"],
      "@webos/ui/input": ["packages/ui/src/input/index.ts"],
      "@webos/ui/input/*": ["packages/ui/src/input/*"],
      "@webos/ui/layout": ["packages/ui/src/layout/index.ts"],
      "@webos/ui/layout/*": ["packages/ui/src/layout/*"],
      "@webos/ui/navigation": ["packages/ui/src/navigation/index.ts"],
      "@webos/ui/navigation/*": ["packages/ui/src/navigation/*"],
      "@webos/ui/components/*": ["packages/ui/src/components/*"],
      "@webos/ui/hooks": ["packages/ui/src/hooks/index.ts"],
      "@webos/ui/utils": ["packages/ui/src/utils/index.ts"],
      "@webos/bootloader": ["packages/bootloader/src/index.ts"],
      "@webos/bootloader/*": ["packages/bootloader/src/*"],
      "@webos/i18n": ["packages/i18n/src/index.ts"],
      "@webos/i18n/*": ["packages/i18n/src/*"],
      "@webos/oobe": ["packages/oobe/src/index.tsx"],
      "@webos/oobe/*": ["packages/oobe/src/*"],
      "@webos/recovery": ["packages/recovery/src/index.tsx"],
      "@webos/recovery/*": ["packages/recovery/src/*"],
      "@webos/apps": ["packages/apps/index.ts"],
      "@webos/apps/*": ["packages/apps/*"],
      "@webos/sdk": ["packages/sdk/src/index.ts"],
      "@webos/sdk/*": ["packages/sdk/src/*"]
    }
  },
  "include": ["packages/**/*", "site/**/*", "crates/**/*", "global.d.ts"],
  "exclude": ["node_modules", "dist", ".next", "crates/**/target"]
}
